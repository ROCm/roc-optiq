# Test Dockerfile for RHEL 8 (Rocky Linux 8) build
# Build and run with:
#   docker build -f Dockerfile.rhel8-test -t rocprofvis-rhel8-test .
#   docker run --rm -it rocprofvis-rhel8-test

FROM rockylinux/rockylinux:8

# Set build arguments
ARG VULKAN_SDK_VERSION=1.4.328.1
ARG ENABLE_INTERNAL_BANNER=OFF

# Install development tools and dependencies
RUN dnf groupinstall -y "Development Tools" && \
    dnf install -y epel-release && \
    dnf config-manager --set-enabled powertools && \
    dnf install -y \
        ca-certificates \
        cmake \
        curl \
        dbus-devel \
        gcc-toolset-11 \
        glibc-devel \
        libX11-devel \
        libXcursor-devel \
        libXi-devel \
        libXinerama-devel \
        libXrandr-devel \
        libxkbcommon-devel \
        mesa-libGL-devel \
        ncurses-devel \
        ninja-build \
        tbb-devel \
        wayland-devel \
        wget \
        git && \
    dnf clean all && \
    echo "✅ Dependencies Installed!"

# Install Vulkan SDK
RUN mkdir -p /opt/vulkan && \
        curl -L --retry 5 --retry-delay 2 \
            https://sdk.lunarg.com/sdk/download/${VULKAN_SDK_VERSION}/linux/vulkansdk-linux-x86_64-${VULKAN_SDK_VERSION}.tar.xz \
            -o /tmp/vulkansdk.tar.xz && \
    tar -xf /tmp/vulkansdk.tar.xz -C /opt/vulkan && \
    rm /tmp/vulkansdk.tar.xz && \
    echo "✅ Vulkan SDK Installed!"

# Clone the repository from GitHub
# Update the URL below to your repository
RUN git clone --recursive https://github.com/ROCm/roc-optiq.git /workspace/rocprofiler-visualizer
# checkout dev branch and update submodules
RUN cd /workspace/rocprofiler-visualizer && \
    git checkout dev && \
    git submodule update --init --recursive
WORKDIR /workspace/rocprofiler-visualizer

# Build the project - Configure
RUN source /opt/vulkan/${VULKAN_SDK_VERSION}/setup-env.sh && \
    source /opt/rh/gcc-toolset-11/enable && \
    mkdir -p build/linux-release && \
    cmake -B build/linux-release --preset "linux-release" \
      -DROCPROFVIS_ENABLE_INTERNAL_BANNER=${ENABLE_INTERNAL_BANNER} \
      -DCMAKE_EXE_LINKER_FLAGS="-ldl -ltbb"

# Build the project - Compile
RUN source /opt/vulkan/${VULKAN_SDK_VERSION}/setup-env.sh && \
    source /opt/rh/gcc-toolset-11/enable && \
    cmake --build build/linux-release --preset "Linux Release Build" --parallel 4 --target package

RUN if [ -e build/linux-release/roc-optiq ]; then \
        echo "✅ roc-optiq has been successfully built!"; \
    else \
        echo "❌ roc-optiq was not built!"; \
        exit 1; \
    fi

# List build artifacts
RUN ls -la build/linux-release/

# Set entrypoint to bash for interactive testing
CMD ["/bin/bash"]
